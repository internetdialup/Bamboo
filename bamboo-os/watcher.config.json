{
  "watch_files": [
    "handoff.md",
    "docs/ctx-orientation.md"
  ],
  "bus_path": "bamboo-os/.bamboo/agent-bus.jsonl",
  "poll_seconds": 2,
  "tail_lines": 20,
  "notify": true,
  "notify_title": "Bamboo Watcher",
  "rules": [
    {
      "pattern": "\\[DIRECTIVE\\]",
      "regex": true,
      "targets": ["all"],
      "message": "New directive issued.",
      "priority": 2
    },
    {
      "pattern": "HALT",
      "targets": ["daemon"],
      "message": "System halt requested. Reload required.",
      "priority": 3,
      "signal": true
    }
  ]
}
